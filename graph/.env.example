# Copy to `.env` (read automatically by `langgraph dev`). All optional —
# defaults match a stock LM Studio install.

# LM Studio local server (OpenAI-compatible endpoint).
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# The orchestrator's reasoning model, as served by LM Studio. Distinct from the
# worker model little-coder drives (set in workflow.yaml: worker_model).
ORCHESTRATOR_MODEL=openai/gpt-oss-20b
